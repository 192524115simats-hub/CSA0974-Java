3. Vehicle Rental Management System
Develop a Java program for a vehicle rental company using Class and Objects.
Data Members:
• Customer ID 
• Customer Name 
• Vehicle Type (Car/Bike) 
• Number of Rental Days 
Methods:
1. Read customer details. 
2. Calculate rental charges. 
3. Add a late return penalty if applicable. 
4. Display the final rental bill. 
Note: Car = ₹2,000/day, Bike = ₹500/day.
CODE
import java.util.Scanner;

class VehicleRental {
    int customerId;
    String customerName;
    String vehicleType;
    int rentalDays;
    double rentalCharges, penalty, finalBill;

    void readDetails() {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Customer ID: ");
        customerId = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Customer Name: ");
        customerName = sc.nextLine();

        System.out.print("Enter Vehicle Type (Car/Bike): ");
        vehicleType = sc.nextLine();

        System.out.print("Enter Number of Rental Days: ");
        rentalDays = sc.nextInt();
    }

    void calculateRentalCharges() {
        if (vehicleType.equalsIgnoreCase("Car")) {
            rentalCharges = rentalDays * 2000;
        } else if (vehicleType.equalsIgnoreCase("Bike")) {
            rentalCharges = rentalDays * 500;
        }

        System.out.print("Enter Late Return Penalty: ");
        Scanner sc = new Scanner(System.in);
        penalty = sc.nextDouble();

        finalBill = rentalCharges + penalty;
    }

    void displayBill() {
        System.out.println("\nRental Bill Details");
        System.out.println("Customer ID: " + customerId);
        System.out.println("Customer Name: " + customerName);
        System.out.println("Vehicle Type: " + vehicleType);
        System.out.println("Rental Days: " + rentalDays);
        System.out.println("Final Bill: " + finalBill);
    }

    public static void main(String[] args) {
        VehicleRental v = new VehicleRental();

        v.readDetails();
        v.calculateRentalCharges();
        v.displayBill();
    }
}
