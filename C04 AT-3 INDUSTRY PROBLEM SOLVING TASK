4. Manufacturing Production Monitoring System
Develop a Java program to monitor daily production in a manufacturing company 
using Class and Objects.Data Members:
• Product ID 
• Product Name 
• Target Quantity 
• Produced Quantity 
Methods:
1. Read product details. 
2. Compare actual production with the target. 
3. Calculate production efficiency percentage. 
4. Display production status (Achieved/Not Achieved). 
Note: Efficiency = (Produced Quantity / Target Quantity) × 100.
CODE
import java.util.Scanner;

class Production {
    int productId;
    String productName;
    int unitsProduced;
    int targetUnits;

    void readDetails() {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter Product ID: ");
        productId = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Product Name: ");
        productName = sc.nextLine();

        System.out.print("Enter Units Produced: ");
        unitsProduced = sc.nextInt();

        System.out.print("Enter Target Units: ");
        targetUnits = sc.nextInt();
    }

    void checkProduction() {
        if (unitsProduced >= targetUnits)
            System.out.println("Production Target Achieved");
        else
            System.out.println("Production Target Not Achieved");
    }

    void displayDetails() {
        System.out.println("\nProduction Details");
        System.out.println("Product ID: " + productId);
        System.out.println("Product Name: " + productName);
        System.out.println("Units Produced: " + unitsProduced);
        System.out.println("Target Units: " + targetUnits);
    }

    public static void main(String[] args) {
        Production p = new Production();

        p.readDetails();
        p.checkProduction();
        p.displayDetails();
    }
}
